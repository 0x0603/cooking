# Ensure consistent line endings across all platforms
* text=auto eol=lf

# Explicitly declare text files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.go text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.sql text eol=lf
*.env text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# Binary files - do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.webm binary
*.zip binary
*.tar.gz binary
*.pdf binary

# Lock files - do not diff
package-lock.json -diff
yarn.lock -diff
pnpm-lock.yaml -diff
go.sum -diff
